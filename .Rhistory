# Load data — paths relative to materials/
df_main <- read_excel(here("data", "data_raw_theglobaleconomy.xlsx"))
df_monetary_policy <- read_excel(here("data", "data_raw_monetary-transmission.xlsx"),
sheet = "data_CWY_annual")
# Keep only the variables needed from the monetary policy dataset
# This assumes df_monetary_policy has the columns: Country, Year, and MPS
mps_subset <- df_monetary_policy[, c("Country", "Year", "MPS")]
# Merge MPS into the main world dataset using Country and Year
# all.x = TRUE keeps all rows from df_world_2000_2019
# If MPS is missing for some country-years (for example after 2019),
# those values will remain NA after the merge
df_world <- merge(
df_main,
mps_subset,
by = c("Country", "Year"),
all.x = TRUE
)
# Sort the merged dataset by Country and Year for readability
df_world <- df_world[order(df_world$Country, df_world$Year), ]
# remove unnecessary dfs
rm(df_main, df_monetary_policy, mps_subset)
